# Copy this to .env and fill in your values
# cp .env.example .env

# ── Twitch ──────────────────────────────────────────────────────────────────
# 1. Get your bot's chat token from https://twitchapps.com/tmi/
#    It will look like: oauth:abc123xyz
TWITCH_BOT_TOKEN=oauth:your_bot_chat_token_here

# 2. Create a Twitch app at https://dev.twitch.tv/console/apps
#    Set OAuth redirect to: http://localhost
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here

# 3. Channel name to join (no #, lowercase)
TWITCH_CHANNEL=your_channel_name

# 4. Broadcaster login — usually same as TWITCH_CHANNEL
#    Only needed if different (e.g. bot account vs. stream account)
BROADCASTER_LOGIN=your_channel_name

# 5. The bot's Twitch account name
BOT_NICK=ClipBot

# ── Discord ─────────────────────────────────────────────────────────────────
# Discord > Channel Settings > Integrations > Webhooks > New Webhook > Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# ── Behavior ────────────────────────────────────────────────────────────────
# Command prefix
COMMAND_PREFIX=

# Who can trigger !clip: broadcaster, moderator, everyone
CLIP_ALLOWED_ROLES=broadcaster,moderator

# Seconds between allowed clip commands
CLIP_COOLDOWN_SECONDS=30
